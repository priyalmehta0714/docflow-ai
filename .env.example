# ========== App ==========
NODE_ENV=development
API_PORT=3001
JWT_SECRET=change-this-to-a-long-random-string

# ========== Database (matches docker-compose) ==========
DATABASE_URL=postgresql://docflow:docflow@localhost:5432/docflow

# ========== Redis (matches docker-compose) ==========
REDIS_URL=redis://localhost:6379

# ========== OpenAI (add your key in .env) ==========
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EXTRACT_MODEL=gpt-4o

# ========== Pinecone (cloud — create index at app.pinecone.io) ==========
PINECONE_API_KEY=
PINECONE_INDEX=docflow-chunks
# Optional: only if your Pinecone project needs it
PINECONE_HOST=

# ========== RAG settings ==========
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.72
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# ========== Uploads ==========
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25