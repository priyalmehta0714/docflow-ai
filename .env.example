# ========== App ==========
NODE_ENV=development
API_PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# ========== Database (local docker-compose uses port 5434) ==========
DATABASE_URL=postgresql://docflow:docflow@127.0.0.1:5434/docflow

# ========== Redis ==========
REDIS_URL=redis://localhost:6379

# ========== OpenAI ==========
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EXTRACT_MODEL=gpt-4o

# ========== Pinecone (index: 1536 dimensions, cosine) ==========
PINECONE_API_KEY=
PINECONE_INDEX=docflow-chunks

# ========== RAG ==========
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# ========== Uploads ==========
UPLOAD_DIR=./apps/api/uploads
MAX_UPLOAD_MB=25

# ========== Production (Railway) example ==========
# NODE_ENV=production
# UPLOAD_DIR=/app/apps/api/uploads
# PORT is set automatically by Railway
