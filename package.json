{
    "name": "docflow-ai",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev:api": "dotenv -e .env -- pnpm --filter @docflow/api dev",
        "dev:worker": "dotenv -e .env -- pnpm --filter @docflow/worker dev",
        "dev:web": "pnpm --filter @docflow/web dev",
        "db:generate": "dotenv -e .env -- pnpm --filter @docflow/db generate",
        "db:migrate": "dotenv -e .env -- pnpm --filter @docflow/db migrate",
        "db:studio": "dotenv -e .env -- pnpm --filter @docflow/db studio",
        "docker:up": "docker compose -f infra/docker-compose.yml up -d",
        "docker:down": "docker compose -f infra/docker-compose.yml down",
        "docker:ps": "docker compose -f infra/docker-compose.yml ps",
        "build": "pnpm db:generate",
        "db:migrate:deploy": "pnpm --filter @docflow/db migrate:deploy",
        "start:prod": "sh scripts/start-production.sh"
    },
    "devDependencies": {
        "dotenv-cli": "^7.4.2"
    },
    "engines": {
        "node": ">=20"
    }
}